{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Restaurant reservation details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "reservationType": { "type": "string", "enum": ["table", "section"] },
        "sectionId": { "type": "string" },
        "tables": { "type": "array", "items": { "type": "integer" } },
        "guestName": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "session": { "type": "string", "enum": ["Breakfast", "Lunch", "Evening", "Dinner"] },
        "guests": { "type": "integer" },
        "tableNumber": { "type": "integer" },
        "specialRequest": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "reserved", "occupied", "VIP"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["guestName", "date", "time", "guests", "status", "session", "reservationType"]
    },
    "Section": {
      "title": "Section",
      "description": "Restaurant section management",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "tables": { "type": "array", "items": { "type": "integer" } },
        "status": { "type": "string", "enum": ["available", "reserved", "maintenance"] }
      },
      "required": ["name", "tables", "status"]
    },
    "Revenue": {
      "title": "Revenue",
      "description": "Daily revenue analytics",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "reservationCount": { "type": "integer" }
      },
      "required": ["date", "amount"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    },
    "reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Collection of all reservations"
    },
    "sections/{sectionId}": {
      "schema": "Section",
      "description": "Collection of restaurant sections"
    },
    "revenue/{revenueId}": {
      "schema": "Revenue",
      "description": "Collection of daily revenue stats"
    }
  }
}
