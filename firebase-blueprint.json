{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["staff", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Outlet": {
      "title": "Outlet",
      "description": "Restaurant outlet configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "gstNumber": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "openingHours": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Enhanced reservation details with history and tracking",
      "type": "object",
      "properties": {
        "guestName": { "type": "string" },
        "phone": { "type": "string" },
        "guests": { "type": "integer" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "session": { "type": "string" },
        "reservationType": { "type": "string", "enum": ["section", "table"] },
        "tableId": { "type": "string" },
        "sectionId": { "type": "string" },
        "hallId": { "type": "string" },
        "outletId": { "type": "string" },
        "status": { "type": "string" },
        "isVIP": { "type": "boolean" },
        "notes": { "type": "string" },
        "internalNotes": { "type": "string" },
        "preorders": { "type": "string" },
        "history": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "note": { "type": "string" }
            }
          }
        },
        "timestamps": {
          "type": "object",
          "properties": {
            "arrivedAt": { "type": "string" },
            "seatedAt": { "type": "string" },
            "diningAt": { "type": "string" },
            "completedAt": { "type": "string" },
            "cancelledAt": { "type": "string" },
            "postponedAt": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["guestName", "phone", "date", "status"]
    },
    "Table": {
      "title": "Table",
      "description": "Individual table configuration with spatial metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sectionId": { "type": "string" },
        "capacity": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "inactive", "reserved", "occupied"] },
        "shape": { "type": "string", "enum": ["square", "round", "rectangle", "sofa"] },
        "type": { "type": "string", "enum": ["standard", "vip", "bar", "outdoor", "booth"] },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "rotation": { "type": "number" },
        "restaurantId": { "type": "string" }
      }
    },
    "Section": {
      "title": "Section",
      "description": "Restaurant sections with layout dimensions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "hallId": { "type": "string" },
        "floor": { "type": "integer" },
        "isOutdoor": { "type": "boolean" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "restaurantId": { "type": "string" }
      }
    },
    "LayoutVersion": {
      "title": "LayoutVersion",
      "description": "Snapshots of restaurant floor plans",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "snapshot": { "type": "string" },
        "isDraft": { "type": "boolean" },
        "isPublished": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Hall": {
      "title": "Hall",
      "description": "Event halls for high tea",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "capacity": { "type": "integer" },
        "basePrice": { "type": "number" }
      }
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "Enhanced food and beverage items with detailed metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "status": { "type": "string", "enum": ["Available", "Out of Stock", "Seasonal", "Chef Special", "Hidden"] },
        "type": { "type": "string", "enum": ["veg", "non-veg"] },
        "menuType": { "type": "string", "enum": ["dine-in", "high-tea"] },
        "prepTime": { "type": "string" },
        "spiceLevel": { "type": "integer" },
        "allergens": { "type": "array", "items": { "type": "string" } },
        "isRecommended": { "type": "boolean" },
        "order": { "type": "integer" }
      }
    }
  },
  "firestore": {
    "outlets/{outletId}": { "schema": "Outlet", "description": "Restaurant outlets" },
    "reservations/{reservationId}": { "schema": "Reservation", "description": "All bookings" },
    "tables/{tableId}": { "schema": "Table", "description": "Restaurant tables" },
    "sections/{sectionId}": { "schema": "Section", "description": "Restaurant sections" },
    "halls/{hallId}": { "schema": "Hall", "description": "Event halls" },
    "menuItems/{itemId}": { "schema": "MenuItem", "description": "Master menu" },
    "layout_versions/{versionId}": { "schema": "LayoutVersion", "description": "Floor plan history" }
  }
}
