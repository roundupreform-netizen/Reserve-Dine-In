rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Outlets: Management of restaurant branches
    match /outlets/{outletId} {
      allow read, write: if true;
    }

    // Reservations
    match /reservations/{resId} {
      allow read, write: if true;
    }
    
    // Menu
    match /menuItems/{itemId} {
      allow read, write: if true;
    }

    match /menuUploadHistory/{id} {
      allow read, write: if true;
    }

    // Layout
    match /sections/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /tables/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /halls/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /layout_versions/{versionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // Immutable history
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if true;
    }

    // Restaurants
    match /restaurants/{restaurantId}/{allPaths=**} {
       allow read, write: if true;
    }

    // Allow the connection test document
    match /test/connection {
      allow read: if true;
    }

    // Default deny: Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
