rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidOutlet(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (data.phone == null || (data.phone is string && data.phone.size() <= 20)) &&
             (data.email == null || (data.email is string && data.email.size() <= 100));
    }

    function isValidReservation(data) {
      return data.guestName is string && data.guestName.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.guests is int && data.guests > 0 && data.guests <= 100 &&
             data.date is string && data.status in ['pending', 'confirmed', 'seated', 'cancelled', 'completed', 'VIP'];
    }

    // Collections
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /outlets/{outletId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidOutlet(incoming()) && isValidId(outletId);
    }

    match /reservations/{resId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidReservation(incoming()) && isValidId(resId);
      allow update: if isSignedIn() && (
        isAdmin() || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes', 'tableId', 'sectionId', 'time', 'guests']))
      ) && isValidReservation(incoming());
      allow delete: if isAdmin();
    }

    match /tables/{tableId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sections/{sectionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /halls/{hallId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /menuItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
